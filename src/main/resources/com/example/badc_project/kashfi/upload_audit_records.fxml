<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.badc_project.kashfi.UploadAuditRecordscontroller">
   <children>
      <Label fx:id="UploadAuditRecordsLabel" layoutX="150.0" layoutY="25.0" text="Upload Audit Records">
         <font>
            <Font size="31.0" />
         </font>
      </Label>
      <Label fx:id="yearLabel" layoutX="36.0" layoutY="95.0" prefHeight="22.0" prefWidth="42.0" text="year:" />
      <Label fx:id="departmentLabel" layoutX="26.0" layoutY="152.0" prefHeight="22.0" prefWidth="81.0" text="department:" />
      <ComboBox fx:id="selectyearComboBox" layoutX="123.0" layoutY="79.0" prefWidth="150.0" promptText="select year" />
      <ComboBox fx:id="selectdepartmentComboBox" layoutX="138.0" layoutY="147.0" prefWidth="150.0" promptText="select department" />
      <Button layoutX="35.0" layoutY="222.0" mnemonicParsing="false" onAction="#choosefileOnAction" text="choose file" />
      <Label fx:id="submitLabel" layoutX="149.0" layoutY="296.0" prefHeight="11.0" prefWidth="140.0" text="submit" />
      <Button layoutX="35.0" layoutY="336.0" mnemonicParsing="false" onAction="#backbuttonOnAction" text="backbutton" />
      <Button layoutX="257.0" layoutY="336.0" mnemonicParsing="false" onAction="#signoutOnAction" text="signout" />
      <Label fx:id="nofilechosenLabel" layoutX="219.0" layoutY="238.0" prefHeight="22.0" prefWidth="178.0" text="no file chosen" />
   </children>
</AnchorPane>
